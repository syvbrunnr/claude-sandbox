# === REQUIRED ===

# Claude Code auth token. Generate with: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=

# Matrix credentials (optional — leave blank to skip Matrix)
MATRIX_HOMESERVER_URL=
MATRIX_USER_ID=
MATRIX_ACCESS_TOKEN=

# === OPTIONAL ===

# FalkorDB password (default: changeme — fine for local use)
FALKORDB_PASSWORD=changeme

# Working directory inside the container
# CLAUDE_WORKDIR=/workspace
